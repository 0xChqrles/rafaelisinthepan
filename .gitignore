# ── Node / Vite ──────────────────────────────────────────────
node_modules
dist
dist-ssr
*.local
.DS_Store
.env
.env.*
!.env.example
# Committed: holds only PUBLIC VITE_* build config (no secrets) so prod builds are reproducible.
!.env.production

# ── Python / uv ──────────────────────────────────────────────
.venv
__pycache__
*.pyc

# ── Editor / tooling local state ─────────────────────────────
.claude/settings.local.json

# ── CDK (issue #3) synth output ──────────────────────────────
cdk.out
packages/infra/cdk.out

# ── Local backend puzzle store (issue #17) ───────────────────
# Puzzles published locally for `pnpm backend:dev`; regenerate/republish at will.
.local-store
packages/backend/.local-store

# ── Generation output (puzzles staged for publish) ───────────
# `pnpm gen:phrase` writes puzzles here; publish them to the store/S3 with
# `pnpm puzzle:publish`. Regenerable artifacts — not tracked. (vocab/<lang>.json
# is a web asset and stays under packages/web/public/vocab.)
packages/generation/output

# ── Embeddings (all excluded — too large for GitHub) ─────────
# Raw sources are multi-GB; even the *_reduced files are 400-500 MB each,
# over GitHub's 100 MB hard limit. Regenerate locally with
# `pnpm reduce:<lang>`, which also rebuilds the .kv caches.
*.vec
*.bin
packages/generation/embedding/**/*.txt
*.kv
*.kv.vectors.npy
*.npy
