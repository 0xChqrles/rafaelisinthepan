{
  "name": "rafaelisinthepan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --filter @rafaelisinthepan/web dev",
    "build": "pnpm --filter @rafaelisinthepan/web build",
    "preview": "pnpm --filter @rafaelisinthepan/web preview",
    "typecheck": "pnpm --filter @rafaelisinthepan/web typecheck",
    "reduce:en": "pnpm --filter @rafaelisinthepan/generation reduce:en",
    "reduce:fr": "pnpm --filter @rafaelisinthepan/generation reduce:fr",
    "gen:phrase": "pnpm --filter @rafaelisinthepan/generation gen:phrase",
    "backend:dev": "pnpm --filter @rafaelisinthepan/backend serve:local",
    "puzzle:publish": "pnpm --filter @rafaelisinthepan/backend puzzle:publish",
    "infra:synth": "pnpm --filter @rafaelisinthepan/infra synth",
    "infra:diff": "pnpm --filter @rafaelisinthepan/infra diff",
    "infra:deploy": "pnpm --filter @rafaelisinthepan/infra run deploy",
    "test": "pnpm -r --workspace-concurrency=1 --if-present run test"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
