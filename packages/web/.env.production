# Production build config (loaded by `vite build`, i.e. `pnpm build`).
# Committed on purpose: VITE_* vars are PUBLIC (baked into the shipped bundle), so this
# is the reproducible prod value — no need to pass VITE_API_BASE_URL on the command line.
#
# Points at the deployed backend's stable custom domain (BackendStack `ApiUrl`, #3/#21).
# `.env.production` takes precedence over the gitignored `.env.local` (localhost) in
# production mode, so local dev (`pnpm dev`) still uses `.env.local`.
VITE_API_BASE_URL=https://api.whippin.ai
