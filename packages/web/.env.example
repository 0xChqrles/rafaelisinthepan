# Base URL of the daily-puzzle backend (Lambda Function URL behind CloudFront, #2).
# The server is the authoritative time source and serves "today's" puzzle.
# Copy to `.env` (or `.env.local`) and set for production / a deployed backend.
#
# Local backend harness (#17): run `pnpm backend:dev` and point this at it, then
# `pnpm dev` resolves today's puzzle end-to-end (no ?puzzle= override needed):
#   VITE_API_BASE_URL=http://localhost:8787
#
# Production (deployed backend, #3 — the BackendStack `ApiUrl` / api.<domain>):
#   VITE_API_BASE_URL=https://api.whippin.ai
#
# Required for dev/build. The frontend must not silently use its own origin as the backend.
VITE_API_BASE_URL=http://localhost:8787
